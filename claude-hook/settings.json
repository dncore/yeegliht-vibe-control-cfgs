{
  "_comment": "Yeelight Vibe Control — Claude Code 全局 hooks 配置",
  "_instructions": "推荐使用 python setup.py 自动完成配置。手动配置时参考 hooks 结构如下。",
  "_test": "配置完成后可测试: python hooks.py direct thinking",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"claude-hook/hooks.py\" user_prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"claude-hook/hooks.py\" pre_tool"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"claude-hook/hooks.py\" post_tool"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"claude-hook/hooks.py\" stop"
          }
        ]
      }
    ]
  }
}
